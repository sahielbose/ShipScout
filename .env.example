# ShipScout environment. Copy to .env.local and fill in.
# Everything is optional for local dev: with no keys, the app runs on the
# seeded dataset (lib/seed) so the full search-to-outreach loop works offline.
# Add keys to switch each part of the engine to live data.

# ----- Database -----
# Postgres with the pgvector extension (Neon or Supabase recommended).
# Leave empty to run on the in-memory seeded dataset.
DATABASE_URL=

# ----- Auth (GitHub OAuth) -----
# Create an OAuth app at https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_SECRET=
# Set to "true" to allow using the app without signing in (local dev only).
NEXT_PUBLIC_ALLOW_GUEST=true

# ----- GitHub data access -----
# A classic or fine-grained PAT (public repo read) is enough for local dev.
# A GitHub App is preferred in production for higher rate limits.
GITHUB_TOKEN=
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=

# ----- LLM and embeddings -----
# Without these, enrichment, outreach, and chat fall back to deterministic
# templates and search uses lexical scoring only.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3
EMBEDDING_DIM=1024

# ----- Background jobs (Inngest) -----
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ----- Optional -----
RESEND_API_KEY=
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=

# ----- Bulk discovery (optional) -----
GCP_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=
