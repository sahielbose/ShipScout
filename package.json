{
  "name": "shipscout",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "Find elite engineers by what they ship. Open source AI sourcing over real GitHub work.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:vector": "tsx prisma/vector-migration.ts",
    "db:seed": "tsx lib/seed/seed.ts",
    "seed": "tsx lib/seed/seed.ts",
    "inngest": "inngest-cli dev",
    "eval": "tsx evals/run.ts",
    "test": "node --import tsx --test \"tests/**/*.test.ts\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "@auth/prisma-adapter": "^2.7.4",
    "@prisma/client": "^6.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^11.15.0",
    "inngest": "^3.27.0",
    "lucide-react": "^0.469.0",
    "next": "^15.5.19",
    "next-auth": "5.0.0-beta.25",
    "octokit": "^4.0.2",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.3",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.5.19",
    "postcss": "^8.4.49",
    "prisma": "^6.2.1",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
